# ingestion
# ---------------------------------------------------------------------------

def _make_event_tuple(
    *,
    csv_row: dict,
    source_file: str,
    source_line: int,
    export_batch: str | None,
    run_id: int,
    ingested_at: str,
) -> tuple[tuple, list[tuple], list[tuple], str | None]:
    """Build the event row tuple plus its child-table rows.

    Returns ``(event_values, mia_rows, consent_rows, parse_error)``.  Both
    child-row lists are empty when the event is not of the relevant type.
    """
    parse_error: str | None = None

    audit_raw = csv_row.get("auditData") or ""
    audit_obj = None
    audit_canon: str | None = None
    if audit_raw:
        try:
            audit_obj = json.loads(audit_raw)
            audit_canon = canonical_json(audit_obj)
        except (json.JSONDecodeError, ValueError) as e:
            parse_error = f"auditData JSON parse error: {e}"

    audit_dict = audit_obj if isinstance(audit_obj, dict) else {}
    promoted = extract_promoted(audit_dict, csv_row.get("clientIp"))

    raw_dt = csv_row.get("createdDateTime") or ""
    iso_dt: str | None = None
    if isinstance(audit_obj, dict):
        iso_dt = parse_created_dt(audit_obj.get("CreationTime") or "")
    if iso_dt is None:
        iso_dt = parse_created_dt(raw_dt)
    if iso_dt is None and raw_dt:
        msg = f"unparseable createdDateTime: {raw_dt!r}"
        parse_error = f"{parse_error}; {msg}" if parse_error else msg

    h = row_hash(csv_row, audit_canon)

    upn_raw = csv_row.get("userPrincipalName") or None
    upn_norm = _normalize_upn(upn_raw)

    values = (
        h, source_file, source_line, export_batch, ingested_at, run_id, parse_error,
        csv_row.get("id"),
        raw_dt or None, iso_dt,
        csv_row.get("auditLogRecordType"),
        csv_row.get("operation"),
        csv_row.get("organizationId"),
        csv_row.get("userType"),
        csv_row.get("userId"),
        csv_row.get("service"),
        csv_row.get("objectId"),
        upn_norm, upn_raw,
        csv_row.get("clientIp") or None,
        csv_row.get("administrativeUnits"),
        audit_raw or None,
        audit_canon,
        promoted["workload"], promoted["client_ip"], promoted["client_ip_raw"],
        promoted["user_agent"],
        promoted["geo_location"], promoted["event_source"],
        promoted["result_status"], promoted["result_status_detail"],
        promoted["correlation_id"], promoted["application_id"], promoted["user_key"],
        promoted["record_type_int"],
        promoted["mailbox_owner_upn"], promoted["mailbox_guid"], promoted["logon_type"],
        promoted["client_info_string"], promoted["internet_message_id"],
        promoted["item_subject"], promoted["item_parent_folder_path"],
        promoted["session_id"], promoted["logon_user_sid"],
        promoted["authentication_type"], promoted["request_type"],
        promoted["user_authentication_method"],
        promoted["device_properties"], promoted["extended_properties"],
        promoted["actor_ip_address"],
        promoted["modified_properties"], promoted["parameters"],
        promoted["operation_properties"],
        promoted["actor_upn"], promoted["target_upn"],
        promoted["site"], promoted["web_id"], promoted["list_id"],
        promoted["list_item_unique_id"], promoted["source_file_name"],
        promoted["source_relative_url"], promoted["item_type"],
        promoted["client_app_id"], promoted["client_app_name"],
        promoted["browser_name"], promoted["browser_version"],
        promoted["platform"], promoted["is_managed_device"],
        promoted["device_display_name"],
        promoted["mail_item_count"],
    )

    op = csv_row.get("operation")
    mia_rows = extract_mia_rows(
        audit_dict,
        event_row_hash=h, event_id=csv_row.get("id"), ingest_run_id=run_id,
        user_principal_name=upn_norm,
        client_ip=promoted["client_ip"],
        created_at_utc=iso_dt,
        operation=op,
        mailbox_owner_upn=promoted["mailbox_owner_upn"],
    )
    consent_rows = extract_consent_grants(
        audit_dict,
        event_row_hash=h, event_id=csv_row.get("id"), ingest_run_id=run_id,
        user_principal_name=upn_norm,
        client_ip=promoted["client_ip"],
        created_at_utc=iso_dt,
        operation=op,
    )

    return values, mia_rows, consent_rows, parse_error


def process_file(
    conn: sqlite3.Connection,
    csv_path: Path,
    input_root: Path,
    run_id: int,
    ingested_at: str,
) -> dict:
    try:
        rel = csv_path.relative_to(input_root).as_posix()
    except ValueError:
        rel = str(csv_path)

    batch_id = export_batch_for(csv_path, input_root)
    stat = csv_path.stat()
    sha = file_sha256(csv_path)
    mtime_iso = datetime.fromtimestamp(stat.st_mtime, tz=UTC).isoformat(timespec="seconds")

    cur = conn.execute(
        "INSERT INTO ingest_files(run_id, source_file, export_batch, sha256, "
        "size_bytes, mtime_utc, status) VALUES (?,?,?,?,?,?, 'started')",
        (run_id, rel, batch_id, sha, stat.st_size, mtime_iso),
    )
    file_id = cur.lastrowid
    conn.commit()

    seen = inserted = duplicate = errors = 0
    mia_emitted = consent_emitted = 0
    row_buf: list[tuple] = []
    mia_buf: list[tuple] = []
    cg_buf: list[tuple] = []
    err_buf: list[tuple] = []

    def _flush_rows() -> None:
        nonlocal inserted, duplicate
        if not row_buf:
            return
        cur2 = conn.executemany(_INSERT_SQL, row_buf)
        ins_now = cur2.rowcount if cur2.rowcount is not None and cur2.rowcount >= 0 else 0
        inserted += ins_now
        duplicate += len(row_buf) - ins_now
        row_buf.clear()

    def _flush_mia() -> None:
        nonlocal mia_emitted
        if not mia_buf:
            return
        cur2 = conn.executemany(_MIA_INSERT_SQL, mia_buf)
        ins_now = cur2.rowcount if cur2.rowcount is not None and cur2.rowcount >= 0 else 0
        mia_emitted += ins_now
        mia_buf.clear()

    def _flush_cg() -> None:
        nonlocal consent_emitted
        if not cg_buf:
            return
        cur2 = conn.executemany(_CG_INSERT_SQL, cg_buf)
        ins_now = cur2.rowcount if cur2.rowcount is not None and cur2.rowcount >= 0 else 0
        consent_emitted += ins_now
        cg_buf.clear()

    def _flush_errs() -> None:
        if not err_buf:
            return
        conn.executemany(
            "INSERT INTO parse_errors(run_id, source_file, source_line, "
            "field, error_type, error_message, raw_excerpt) "
            "VALUES (?,?,?,?,?,?,?)",
            err_buf,
        )
        err_buf.clear()

    info(f"  {dim('->')} {rel}  ({stat.st_size / 1_048_576:.1f} MiB)")

    try:
        with open(csv_path, encoding="utf-8-sig", newline="") as f:
            reader = csv.DictReader(f)
            if reader.fieldnames is None or [c.strip() for c in reader.fieldnames] != EXPECTED_HEADER:
                msg = f"unexpected header: {reader.fieldnames!r}"
                conn.execute(
                    "UPDATE ingest_files SET status='skipped', error_message=? "
                    "WHERE file_id=?",
                    (msg, file_id),
                )
                conn.commit()
                warn(f"     skipped: {msg}")
                return {
                    "seen": 0, "inserted": 0, "duplicate": 0, "errors": 0,
                    "mia_emitted": 0, "consent_emitted": 0,
                    "skipped": True,
                }

            for line_no, raw_row in enumerate(reader, start=2):
                seen += 1
                try:
                    values, mia_rows, cg_rows, perr = _make_event_tuple(
                        csv_row=raw_row,
                        source_file=rel,
                        source_line=line_no,
                        export_batch=batch_id,
                        run_id=run_id,
                        ingested_at=ingested_at,
                    )
                    row_buf.append(values)
                    if mia_rows:
                        mia_buf.extend(mia_rows)
                    if cg_rows:
                        cg_buf.extend(cg_rows)
                    if perr:
                        errors += 1
                        err_buf.append((
                            run_id, rel, line_no, "auditData",
                            "ParseError", perr,
                            (raw_row.get("auditData") or "")[:500],
                        ))
                except Exception as e:
                    errors += 1
                    err_buf.append((
                        run_id, rel, line_no, None,
                        type(e).__name__, str(e), None,
                    ))

                # FK ordering: events MUST be flushed before their child
                # rows, because the child tables foreign-key into events.row_hash.
                # When ANY buffer is full, flush events first, then children.
                if (
                    len(row_buf) >= _BATCH_SIZE
                    or len(mia_buf) >= _BATCH_SIZE
                    or len(cg_buf) >= _BATCH_SIZE
                ):
                    _flush_rows()
                    _flush_mia()
                    _flush_cg()
                if len(err_buf) >= _BATCH_SIZE:
                    _flush_errs()
                if seen % _PROGRESS_EVERY == 0:
                    info(
                        f"     ... {seen:,} rows read "
                        f"(inserted {inserted:,}, dup {duplicate:,}, err {errors:,})"
                    )

            _flush_rows()
            _flush_mia()
            _flush_cg()
            _flush_errs()
    except csv.Error as e:
        _flush_rows()
        _flush_mia()
        _flush_cg()
        _flush_errs()
        conn.execute(
            "UPDATE ingest_files SET status='failed', error_message=?, "
            "rows_seen=?, rows_inserted=?, rows_duplicate=?, rows_with_errors=? "
            "WHERE file_id=?",
            (f"csv error: {e}", seen, inserted, duplicate, errors, file_id),
        )
        conn.commit()
        err(f"     failed: {e}")
        return {
            "seen": seen, "inserted": inserted, "duplicate": duplicate,
            "errors": errors, "mia_emitted": mia_emitted,
            "consent_emitted": consent_emitted,
            "skipped": False, "failed": True,
        }

    conn.execute(
        "UPDATE ingest_files SET status='ok', rows_seen=?, rows_inserted=?, "
        "rows_duplicate=?, rows_with_errors=? WHERE file_id=?",
        (seen, inserted, duplicate, errors, file_id),
    )
    conn.commit()
    extra = ""
    if mia_emitted or consent_emitted:
        bits = []
        if mia_emitted:
            bits.append(f"{mia_emitted:,} mail items")
        if consent_emitted:
            bits.append(f"{consent_emitted:,} consent grants")
        extra = " + " + ", ".join(bits)
    ok(
        f"     done: {seen:,} rows  ({inserted:,} inserted, "
        f"{duplicate:,} duplicate, {errors:,} with errors){extra}"
    )
    return {
        "seen": seen, "inserted": inserted, "duplicate": duplicate,
        "errors": errors, "mia_emitted": mia_emitted,
        "consent_emitted": consent_emitted,
        "skipped": False,
    }


