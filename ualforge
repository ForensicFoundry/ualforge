APPLICATION_ID = 0x55414C48

# Schema version contract:
#   Bumped any time the events / child-table shape or the promotion logic
#   changes in a way that would make an old database incomplete or wrongly
#   indexed.  bec-triage strictly enforces this number and refuses to run
#   against a database that doesn't match.
#
#   v1: original wide events table; field-name promoter; no child tables.
#   v2: full alias-chain promoter (closes the MailItemsAccessed / RecordType
#       50 gap), normalized client_ip + lowercase user_principal_name with
#       *_raw provenance columns, ExtendedProperties + ActorInfoString
#       parsing, and two child tables (mail_items_accessed, consent_grants)
#       so per-message and per-app pivots are first-class queryable.
