# coverage diagnostic
# ---------------------------------------------------------------------------

def compute_coverage(conn: sqlite3.Connection, run_id: int | None) -> dict:
    """Compute the coverage report.

    When ``run_id`` is given, statistics are scoped to events ingested in
    that one run -- this is what the normal ingest path uses.  When
    ``run_id`` is ``None``, statistics are computed over the full database
    -- this is what ``--reextract`` uses, since it touches every existing
    row but does not change ``ingest_run_id`` on those rows.

    The intent is twofold: (1) tell the analyst at a glance how complete
    the promotion is, and (2) make any silent regression after a future
    schema / promoter change immediately visible (a coverage drop on
    re-extract is evidence of a bug).
    """
    if run_id is None:
        ev_pred = ""
        ev_params: tuple = ()
        child_pred = ""
        child_params: tuple = ()
    else:
        ev_pred = " WHERE ingest_run_id = ?"
        ev_params = (run_id,)
        child_pred = " WHERE ingest_run_id = ?"
        child_params = (run_id,)

    def _q1(sql: str, params: tuple = ()) -> int:
        row = conn.execute(sql, params).fetchone()
        return int(row[0] or 0) if row else 0

    total = _q1(f"SELECT COUNT(*) FROM events{ev_pred}", ev_params)
    if total == 0:
        return {
            "run_id": run_id, "events_total": 0,
            "client_ip_pct": None, "user_agent_pct": None,
            "application_id_pct": None, "user_principal_name_pct": None,
            "mia_events": 0, "mia_rows": 0, "mia_avg_items": None,
            "consent_events": 0, "consent_rows": 0,
        }

    def _pct(populated: int) -> float:
        return round(100.0 * populated / total, 2)

    def _populated(col: str) -> int:
        if ev_pred:
            sql = (
                f"SELECT COUNT(*) FROM events{ev_pred} "
                f"  AND {col} IS NOT NULL AND {col} <> ''"
            )
        else:
            sql = (
                f"SELECT COUNT(*) FROM events "
                f"WHERE {col} IS NOT NULL AND {col} <> ''"
            )
        return _q1(sql, ev_params)

    cov = {
        "run_id": run_id,
        "events_total": total,
        "client_ip_pct":             _pct(_populated("client_ip")),
        "user_agent_pct":            _pct(_populated("user_agent")),
        "application_id_pct":        _pct(_populated("application_id")),
        "user_principal_name_pct":   _pct(_populated("user_principal_name")),
    }

    if ev_pred:
        mia_events_sql = (
            f"SELECT COUNT(*) FROM events{ev_pred} AND record_type_int = 50"
        )
    else:
        mia_events_sql = (
            "SELECT COUNT(*) FROM events WHERE record_type_int = 50"
        )
    mia_events = _q1(mia_events_sql, ev_params)
    mia_rows = _q1(f"SELECT COUNT(*) FROM mail_items_accessed{child_pred}",
                   child_params)
    cov["mia_events"] = mia_events
    cov["mia_rows"] = mia_rows
    cov["mia_avg_items"] = (
        round(mia_rows / mia_events, 2) if mia_events else None
    )

    consent_op_in = (
        "operation IN ('Consent to application.','Add OAuth2PermissionGrant.',"
        "'Add delegated permission grant.','Add app role assignment grant to user.',"
        "'Add app role assignment to service principal.',"
        "'Add service principal.','Add service principal credentials.')"
    )
    if ev_pred:
        consent_evt_sql = (
            f"SELECT COUNT(*) FROM events{ev_pred} AND {consent_op_in}"
        )
    else:
        consent_evt_sql = f"SELECT COUNT(*) FROM events WHERE {consent_op_in}"
    consent_events = _q1(consent_evt_sql, ev_params)
    consent_rows = _q1(f"SELECT COUNT(*) FROM consent_grants{child_pred}",
                       child_params)
    cov["consent_events"] = consent_events
    cov["consent_rows"] = consent_rows
    return cov


def _emit_coverage(cov: dict) -> None:
    if cov["events_total"] == 0:
        warn("  (no events were inserted in this run; skipping coverage report)")
        return
    blank()
    header("Coverage report")
    info(f"  Events ingested:           {cov['events_total']:,}")
    info(f"  client_ip populated:       {cov['client_ip_pct']:>6.2f}%")
    info(f"  user_agent populated:      {cov['user_agent_pct']:>6.2f}%")
    info(f"  application_id populated:  {cov['application_id_pct']:>6.2f}%")
    info(f"  user_principal_name pop'd: {cov['user_principal_name_pct']:>6.2f}%")
    if cov["mia_events"]:
        info(
            f"  MailItemsAccessed events:  {cov['mia_events']:,} "
            f"-> {cov['mia_rows']:,} per-message rows "
            f"(avg {cov['mia_avg_items']} items/event)"
        )
    if cov["consent_events"]:
        info(
            f"  Consent / SP-grant events: {cov['consent_events']:,} "
            f"-> {cov['consent_rows']:,} consent_grants rows"
        )


