def _color_enabled() -> bool:
    if os.environ.get("NO_COLOR"):
        return False
    if not sys.stdout.isatty():
        return False
    if sys.platform == "win32":
        try:
            os.system("")
        except Exception:
            return False
    return True


_USE_COLOR = _color_enabled()

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
BLUE = "\033[34m"
MAGENTA = "\033[35m"
CYAN = "\033[36m"


def paint(text, *codes) -> str:
    if not _USE_COLOR or not codes:
        return str(text)
    return "".join(codes) + str(text) + RESET


_ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


class _LogWriter:
    def __init__(self) -> None:
        self.path: Path | None = None
        self._fh = None

    def open(self, path: Path) -> None:
        self._fh = open(path, "w", encoding="utf-8", newline="")
        self.path = path

    def write(self, text: str) -> None:
        if self._fh is None:
            return
        try:
            self._fh.write(_ANSI_RE.sub("", text) + "\n")
            self._fh.flush()
        except Exception:
            pass

    def close(self) -> None:
        if self._fh is not None:
            try:
                self._fh.close()
            except Exception:
                pass
            self._fh = None


_LOG = _LogWriter()


def _emit(text: str, *, stream=None) -> None:
    print(text, file=stream or sys.stdout, flush=True)
    _LOG.write(text)


def info(msg: str) -> None:
    _emit(paint(msg, CYAN))


def header(msg: str) -> None:
    _emit(paint(msg, BOLD, BLUE))


def ok(msg: str) -> None:
    _emit(paint(msg, GREEN))


def warn(msg: str) -> None:
    _emit(paint(msg, YELLOW))


def err(msg: str) -> None:
    _emit(paint(msg, RED), stream=sys.stderr)


def blank() -> None:
    print(flush=True)
    _LOG.write("")


def dim(msg: str) -> str:
    return paint(msg, DIM)


_IN_FLIGHT_PARTIALS: set[Path] = set()


def _cleanup_partials() -> None:
    for p in list(_IN_FLIGHT_PARTIALS):
        try:
            if p.exists():
                p.unlink()
        except Exception:
            pass
        _IN_FLIGHT_PARTIALS.discard(p)


def _signal_handler(signum, _frame):
    _cleanup_partials()
    err(f"\n{_SCRIPT_NAME}: interrupted by signal {signum}; cleaned up partial files.")
    sys.exit(130 if signum == signal.SIGINT else 1)


atexit.register(_cleanup_partials)
atexit.register(_LOG.close)
signal.signal(signal.SIGINT, _signal_handler)
if hasattr(signal, "SIGTERM"):
    signal.signal(signal.SIGTERM, _signal_handler)


