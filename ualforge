# Child-table emitters
# ---------------------------------------------------------------------------

def extract_mia_rows(
    audit: dict,
    *,
    event_row_hash: str,
    event_id: str | None,
    ingest_run_id: int,
    user_principal_name: str | None,
    client_ip: str | None,
    created_at_utc: str | None,
    operation: str | None,
    mailbox_owner_upn: str | None,
) -> list[tuple]:
    """One row per accessed mail item from ``Folders[].FolderItems[]``.

    Returns an empty list for non-MailItemsAccessed events or when the
    Folders array is absent / empty / malformed -- the caller never needs
    to special-case the result.
    """
    rt = audit.get("RecordType")
    if rt != 50:
        return []
    folders = audit.get("Folders")
    if not isinstance(folders, list):
        return []
    out: list[tuple] = []
    for folder in folders:
        if not isinstance(folder, dict):
            continue
        folder_id = folder.get("Id")
        folder_path = folder.get("Path")
        items = folder.get("FolderItems")
        if not isinstance(items, list):
            continue
        for it in items:
            if not isinstance(it, dict):
                continue
            size = it.get("SizeInBytes")
            if isinstance(size, str) and size.isdigit():
                size = int(size)
            elif not isinstance(size, int):
                size = None
            out.append((
                event_row_hash, event_id, ingest_run_id,
                user_principal_name, client_ip, created_at_utc, operation,
                mailbox_owner_upn,
                folder_id, folder_path,
                it.get("Id"), it.get("InternetMessageId"),
                it.get("Subject"), size,
                it.get("ClientRequestId"), it.get("ImmutableId"),
            ))
    return out


# Operations that produce a consent / service-principal grant the analyst
# wants pivoted in the consent_grants child table.  This list is the union of
# every consent-shaped operation Microsoft has emitted across RecordTypes 8
# and 15 over the years (note the trailing periods -- Microsoft includes them).
_CONSENT_OPERATIONS: frozenset[str] = frozenset({
    "Consent to application.",
    "Add OAuth2PermissionGrant.",
    "Add delegated permission grant.",
    "Add app role assignment grant to user.",
    "Add app role assignment to service principal.",
    "Add service principal.",
    "Add service principal credentials.",
    "Update application - Certificates and secrets management",
    "Update application \u2013 Certificates and secrets management",
})


def _parse_target_app(target) -> tuple[str | None, str | None]:
    """Pull ``(app_id, app_display_name)`` out of an auditData ``Target`` array."""
    if not isinstance(target, list):
        return None, None
    app_id = None
    app_name = None
    for entry in target:
        if not isinstance(entry, dict):
            continue
        ident = entry.get("ID") or entry.get("Id")
        if not isinstance(ident, str):
            continue
        if "@" in ident:
            continue  # that's a UPN; skip
        # Heuristic: bare GUID = app id; everything else = display name.
        if re.fullmatch(r"[0-9a-fA-F-]{30,}", ident):
            if app_id is None:
                app_id = ident
        elif app_name is None:
            app_name = ident
    return app_id, app_name


def _parse_modified_properties(modprops) -> dict[str, str | None]:
    """Walk a ``ModifiedProperties`` array, indexing by ``Name``.

    Returns the canonical view of consent-shaped sub-fields (permissions,
    consent type, etc.) using both ``NewValue`` and ``OldValue`` so a
    consent-revocation also has its scope captured.
    """
    out: dict[str, str | None] = {}
    if not isinstance(modprops, list):
        return out
    for entry in modprops:
        if not isinstance(entry, dict):
            continue
        name = entry.get("Name")
        if not isinstance(name, str):
            continue
        v = entry.get("NewValue")
        if v in (None, ""):
            v = entry.get("OldValue")
        out[name] = str(v) if v not in (None, "") else None
    return out


def extract_consent_grants(
    audit: dict,
    *,
    event_row_hash: str,
    event_id: str | None,
    ingest_run_id: int,
    user_principal_name: str | None,
    client_ip: str | None,
    created_at_utc: str | None,
    operation: str | None,
) -> list[tuple]:
    """One row per consent / service-principal grant.

    Returns an empty list for events that aren't consent-shaped, so the
    caller never needs to special-case.
    """
    if operation not in _CONSENT_OPERATIONS:
        return []
    target = audit.get("Target")
    app_id, app_name = _parse_target_app(target)
    if app_id is None and app_name is None:
        # Fall back to top-level fields some sub-schemas use.
        app_id = audit.get("ApplicationId") or audit.get("AppId")
        app_name = audit.get("ApplicationDisplayName") or audit.get("ClientAppName")
    if app_id is None and app_name is None:
        # No identifiable app -- skip rather than write a useless row.
        return []

    mp = _parse_modified_properties(audit.get("ModifiedProperties"))
    permissions = (
        mp.get("ConsentAction.Permissions")
        or mp.get("DelegationEntry.NewValue")
        or mp.get("Included Updated Properties")
    )
    # Microsoft's ConsentAction.Permissions string looks like
    # "[[Scope: Mail.Read]; [Scope: offline_access]]" -- normalize it.
    if isinstance(permissions, str):
        permissions = permissions.strip()
    consent_type = mp.get("ConsentContext.IsAdminConsent")
    is_admin = None
    if isinstance(consent_type, str):
        is_admin = 1 if consent_type.strip().lower() == "true" else 0
    consent_type_str = mp.get("ConsentContext.OnBehalfOfAll")
    if isinstance(consent_type_str, str):
        consent_type_str = (
            "AllPrincipals" if consent_type_str.strip().lower() == "true"
            else "Principal"
        )
    if is_admin == 1:
        consent_type_str = "AdminConsent"

    granted_to_id = audit.get("UserId") or user_principal_name
    granted_to_name = audit.get("UserDisplayName")

    return [(
        event_row_hash, event_id, ingest_run_id,
        user_principal_name, client_ip, created_at_utc, operation,
        app_id, app_name,
        consent_type_str, is_admin, permissions,
        granted_to_id, granted_to_name,
    )]


def row_hash(csv_row: dict, audit_canonical: str | None) -> str:
    """Full-row SHA-256: every CSV column plus the canonical auditData."""
    parts = [csv_row.get(k) or "" for k in EXPECTED_HEADER[:-1]]
    parts.append(audit_canonical or csv_row.get("auditData") or "")
    h = hashlib.sha256()
    h.update("\x1f".join(parts).encode("utf-8", errors="replace"))
    return h.hexdigest()


# ---------------------------------------------------------------------------
# file helpers
# ---------------------------------------------------------------------------

_BATCH_SIZE = 500
_PROGRESS_EVERY = 25_000


def file_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def export_batch_for(path: Path, root: Path) -> str | None:
    """Identify the Microsoft export-pull folder, e.g. '20260301-12345'."""
    try:
        rel = path.relative_to(root)
    except ValueError:
        return None
    for part in rel.parts:
        if re.fullmatch(r"\d{8}-\d{6}", part):
            return part
    return None


