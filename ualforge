# ---------------------------------------------------------------------------
# database open / verify
# ---------------------------------------------------------------------------

def open_db(path: Path) -> sqlite3.Connection:
    path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(path)
    conn.execute("PRAGMA journal_mode = WAL")
    conn.execute("PRAGMA synchronous = NORMAL")
    conn.execute("PRAGMA temp_store = MEMORY")
    conn.execute("PRAGMA cache_size = -65536")  # ~64 MiB page cache
    conn.execute("PRAGMA foreign_keys = ON")
    return conn


def init_schema(conn: sqlite3.Connection) -> None:
    conn.execute(f"PRAGMA application_id = {APPLICATION_ID}")
    conn.execute(f"PRAGMA user_version = {SCHEMA_VERSION}")
    for ddl in _SCHEMA_DDL:
        conn.execute(ddl)
    for ddl in _INDEX_DDL:
        conn.execute(ddl)
    now = datetime.now(UTC).isoformat(timespec="seconds")
    conn.executemany(
        "INSERT OR IGNORE INTO ualforge_meta(key, value) VALUES(?, ?)",
        [
            ("app", APP_NAME),
            ("schema_version", str(SCHEMA_VERSION)),
            ("created_at", now),
            ("created_by_version", VERSION),
        ],
    )
    conn.executemany(
        "INSERT OR REPLACE INTO ualforge_meta(key, value) VALUES(?, ?)",
        [
            ("last_opened_at", now),
            ("last_opened_by_version", VERSION),
        ],
    )
    conn.commit()


def verify_ualforge_db(path: Path) -> tuple[bool, str]:
    """Return ``(ok, reason)``.  Conservative: every check must pass."""
    if not path.exists():
        return False, f"file does not exist: {path}"
    if not path.is_file():
        return False, f"path is not a file: {path}"
    try:
        conn = sqlite3.connect(path)
    except sqlite3.Error as e:
        return False, f"could not open as SQLite: {e}"
    try:
        app_id = conn.execute("PRAGMA application_id").fetchone()[0]
        if app_id != APPLICATION_ID:
            return False, (
                f"PRAGMA application_id is {app_id:#010x}, expected "
                f"{APPLICATION_ID:#010x} ('UALH')"
            )
        ver = conn.execute("PRAGMA user_version").fetchone()[0]
        row = conn.execute(
            "SELECT name FROM sqlite_master "
            "WHERE type='table' AND name='ualforge_meta'"
        ).fetchone()
        if row is None:
            return False, "missing ualforge_meta table"
        row = conn.execute(
            "SELECT value FROM ualforge_meta WHERE key='app'"
        ).fetchone()
        if row is None or row[0] != APP_NAME:
            return False, "ualforge_meta.app is not 'ualforge'"
        if ver != SCHEMA_VERSION:
            return False, (
                f"schema_version mismatch: db user_version={ver}, "
                f"this {APP_NAME} expects {SCHEMA_VERSION}.  "
                f"Re-ingest from the source CSVs, or run "
                f"`{_SCRIPT_NAME} --reextract <DB>` to upgrade the promoted "
                f"columns and rebuild child tables in place from the "
                f"preserved auditData JSON."
            )
        return True, "ok"
    finally:
        conn.close()


# ---------------------------------------------------------------------------
# CSV discovery
# ---------------------------------------------------------------------------

_PRIMARY_NAME_RE = re.compile(r"UnifiedAuditLog.*part\d+\.csv$", re.IGNORECASE)


def _is_valid_ual_csv(path: Path) -> tuple[bool, str]:
    try:
        with open(path, encoding="utf-8-sig", newline="") as f:
            reader = csv.reader(f)
            try:
                hdr = next(reader)
            except StopIteration:
                return False, "empty file"
        if [c.strip() for c in hdr] != EXPECTED_HEADER:
            return False, "header does not match the UAL schema exactly"
        return True, "ok"
    except OSError as e:
        return False, f"read error: {e}"
    except UnicodeDecodeError as e:
        return False, f"not UTF-8 text: {e}"


def find_ual_csvs(input_dir: Path) -> tuple[list[Path], list[tuple[Path, str]]]:
    """Discover UAL CSVs.

    Plan A: any ``*UnifiedAuditLog*part<N>.csv`` under ``input_dir``.
    Plan B (only if A finds nothing): every ``*.csv`` under ``input_dir``,
    each individually validated against ``EXPECTED_HEADER``.
    """
    rejected: list[tuple[Path, str]] = []

    plan_a = sorted(
        p for p in input_dir.rglob("*.csv")
        if _PRIMARY_NAME_RE.search(p.name)
    )
    if plan_a:
        accepted: list[Path] = []
        for p in plan_a:
            ok_v, reason = _is_valid_ual_csv(p)
            if ok_v:
                accepted.append(p)
            else:
                rejected.append((p, reason))
        return accepted, rejected

    info("No primary-pattern UAL files found; falling back to structural scan of all .csv files.")
    accepted = []
    for p in sorted(input_dir.rglob("*.csv")):
        ok_v, reason = _is_valid_ual_csv(p)
        if ok_v:
            accepted.append(p)
        else:
            rejected.append((p, reason))
    return accepted, rejected


# ---------------------------------------------------------------------------
# parsers
# ---------------------------------------------------------------------------

# Microsoft delivers ``createdDateTime`` in US locale ``M/D/YYYY h:mm:ss AM/PM``
# wall-clock time that matches ``auditData.CreationTime`` (which is ISO-8601
# UTC with a trailing 'Z'); we treat the CSV value as UTC when the JSON value
# is missing.
_DT_FORMATS = (
    "%m/%d/%Y %I:%M:%S %p",
    "%m/%d/%Y %I:%M %p",
    "%m/%d/%Y %H:%M:%S",
    "%Y-%m-%dT%H:%M:%SZ",
    "%Y-%m-%dT%H:%M:%S.%fZ",
    "%Y-%m-%dT%H:%M:%S",
)


def parse_created_dt(raw: str) -> str | None:
    if not raw:
        return None
    s = raw.strip()
    for fmt in _DT_FORMATS:
        try:
            dt = datetime.strptime(s, fmt)
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=UTC)
            else:
                dt = dt.astimezone(UTC)
            return dt.isoformat(timespec="seconds")
        except ValueError:
            continue
    try:
        dt = datetime.fromisoformat(s.replace("Z", "+00:00"))
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=UTC)
    else:
        dt = dt.astimezone(UTC)
    return dt.isoformat(timespec="seconds")


def canonical_json(obj) -> str:
    return json.dumps(obj, sort_keys=True, separators=(",", ":"), ensure_ascii=False)


def _first_upn_id(arr) -> str | None:
    """For Azure-AD ``Actor`` / ``Target`` arrays, return the first ``ID``
    that looks like a UPN (contains '@'); else the first ``ID``."""
    if not isinstance(arr, list):
        return None
    first = None
    for item in arr:
        if not isinstance(item, dict):
            continue
        ident = item.get("ID")
        if not ident:
            continue
        if first is None:
            first = ident
        if isinstance(ident, str) and "@" in ident:
            return ident
    return first


def _maybe_json(obj) -> str | None:
    if obj is None:
        return None
    if isinstance(obj, str):
        return obj
    if isinstance(obj, (int, float, bool)):
        return str(obj)
    return canonical_json(obj)


def _first_present(audit: dict, *names: str):
    """Return the first non-empty value from a chain of alternative key names.

    Microsoft uses different field names for the same logical concept across
    UAL ``RecordType`` schemas (``ClientIP`` vs ``ClientIPAddress`` vs
    ``IPAddress``, ``ApplicationId`` vs ``AppId`` vs ``ClientAppId``, etc.).
    This collapses every alias chain into a single helper so the promoter can
    declare "I want the source IP, here are the field names Microsoft has
    historically used for it" rather than scattering ``or`` chains.

    Empty strings are treated as missing -- some Microsoft sub-schemas emit
    ``""`` rather than omitting the field.
    """
    for n in names:
        v = audit.get(n)
        if v not in (None, ""):
            return v
    return None


def _ext_prop(extended, name: str) -> str | None:
    """Look up ``Value`` for the named entry in an ``ExtendedProperties`` array.

    Microsoft serialises a number of high-value attributes (``UserAgent``,
    ``RequestType``, ``UserAuthenticationMethod``, ``ResultStatusDetail``)
    inside an array of ``{Name, Value}`` dicts rather than as top-level keys.
    """
    if not isinstance(extended, list):
        return None
    for entry in extended:
        if not isinstance(entry, dict):
            continue
        if entry.get("Name") == name:
            v = entry.get("Value")
            if v not in (None, ""):
                return str(v)
    return None


def _ua_from_extended_properties(extended) -> str | None:
    return _ext_prop(extended, "UserAgent")


_ACTOR_INFO_UA_RE = re.compile(r"UserAgent=([^;]+)")


def _ua_from_actor_info_string(s) -> str | None:
    """Pull ``UserAgent=...`` out of the ``ActorInfoString`` semicolon-list.

    For ``MailItemsAccessed`` (RecordType 50) and other REST/Graph events
    Microsoft puts the user-agent inside ``ActorInfoString`` like::

        Client=REST;Client=RESTSystem;UserAgent=[NoUserAgent][AppId=...];

    The literal ``[NoUserAgent]`` value is preserved verbatim; it is itself
    a forensically meaningful signal (= app-only / token-based caller).
    """
    if not isinstance(s, str) or not s:
        return None
    m = _ACTOR_INFO_UA_RE.search(s)
    return m.group(1).strip() if m else None


_IPV4_PORT_RE = re.compile(r"^(\d{1,3}(?:\.\d{1,3}){3}):\d+$")
_IPV6_BRACKET_PORT_RE = re.compile(r"^\[([^\]]+)\]:\d+$")
_IPV6_BRACKET_RE = re.compile(r"^\[([^\]]+)\]$")


def _normalize_ip(value) -> str | None:
    """Strip ephemeral port and IPv6 brackets from a ClientIP value.

    The TCP source port is picked by the actor's OS for every new session,
    so it has no forensic value; including it splits one identity into
    many under naive ``GROUP BY``.  Brackets only matter when a port is
    present, so they are stripped for cleanliness.
    """
    if value is None:
        return None
    s = str(value)
    if not s:
        return None
    if (m := _IPV4_PORT_RE.match(s)):
        return m.group(1)
    if (m := _IPV6_BRACKET_PORT_RE.match(s)):
        return m.group(1)
    if (m := _IPV6_BRACKET_RE.match(s)):
        return m.group(1)
    return s


def _normalize_upn(value) -> str | None:
    """Lowercase a user_principal_name; preserve None / empty as-is.

    UAL inconsistently emits the same identity with multiple casings
    (``User.Name@x.com`` and ``user.name@x.com``); normalising at ingest
    means every downstream query can do plain ``= ?`` instead of
    ``LOWER(user_principal_name) = ?``.
    """
    if value is None:
        return None
    s = str(value).strip()
    if not s:
        return None
    return s.lower()


# ---------------------------------------------------------------------------
# RecordType-aware promotion
# ---------------------------------------------------------------------------
#
# Microsoft's UAL schema is a union of dozens of per-product schemas tagged
# by ``RecordType``.  The fields we care about live under different names
# in each.  ``extract_promoted`` builds a "best-effort default" view using
# alias chains, then a small per-RecordType specializer fills in or
# overrides values that only that schema knows about.
#
# Reference: https://learn.microsoft.com/en-us/office/office-365-management-api/
#            office-365-management-activity-api-schema
# ---------------------------------------------------------------------------

# Aliases for the source IP across Exchange / SharePoint / AAD / Graph schemas.
_IP_ALIASES = ("ClientIP", "ClientIp", "ClientIPAddress",
               "IPAddress", "IpAddress", "ActorIpAddress")

# Aliases for "the application that performed this action".
_APP_ID_ALIASES = ("ApplicationId", "AppId", "ClientAppId")


def extract_promoted(audit: dict, csv_client_ip: str | None) -> dict:
    """Pull BEC-relevant scalar fields out of the auditData JSON.

    This is the v2 promoter: full alias chains for fields Microsoft renames
    across RecordTypes, ``ExtendedProperties`` walked for AAD-style sub-keys,
    ``ActorInfoString`` parsed for the embedded UserAgent, and a per-RecordType
    specializer that fills schema-specific gaps (notably MailItemsAccessed).

    All IP and UPN values are normalized; provenance copies of the original
    strings are returned in ``client_ip_raw`` and ``user_principal_name_raw``
    so the analyst never loses Microsoft's verbatim record.
    """
    g = audit.get
    item = g("Item") if isinstance(g("Item"), dict) else {}
    parent = item.get("ParentFolder") if isinstance(item.get("ParentFolder"), dict) else {}
    is_managed = g("IsManagedDevice")
    record_type = g("RecordType")
    extended = g("ExtendedProperties")

    raw_ip = _first_present(audit, *_IP_ALIASES)
    if raw_ip in (None, "") and csv_client_ip:
        raw_ip = csv_client_ip
    norm_ip = _normalize_ip(raw_ip)

    user_agent = (
        _first_present(audit, "UserAgent")
        or _ua_from_extended_properties(extended)
        or _ua_from_actor_info_string(g("ActorInfoString"))
    )

    promoted = {
        "workload":            g("Workload"),
        "client_ip":           norm_ip,
        "client_ip_raw":       raw_ip if raw_ip not in (None, "") else None,
        "user_agent":          user_agent,
        "geo_location":        g("GeoLocation"),
        "event_source":        g("EventSource"),
        "result_status":       g("ResultStatus"),
        "result_status_detail": (
            g("ResultStatusDetail") or _ext_prop(extended, "ResultStatusDetail")
        ),
        "correlation_id":      g("CorrelationId"),
        "application_id":      _first_present(audit, *_APP_ID_ALIASES),
        "user_key":            g("UserKey"),
        "record_type_int":     record_type if isinstance(record_type, int) else None,
        "mailbox_owner_upn":   _normalize_upn(g("MailboxOwnerUPN")),
        "mailbox_guid":        g("MailboxGuid"),
        "logon_type":          str(g("LogonType")) if g("LogonType") is not None else None,
        "client_info_string":  g("ClientInfoString"),
        "internet_message_id": item.get("InternetMessageId") or g("InternetMessageId"),
        "item_subject":        item.get("Subject"),
        "item_parent_folder_path": parent.get("Path"),
        "session_id":          g("SessionId"),
        "logon_user_sid":      g("LogonUserSid"),
        "authentication_type": (
            g("AuthenticationType") or _ext_prop(extended, "RequestType")
        ),
        "request_type":        _ext_prop(extended, "RequestType"),
        "user_authentication_method": _ext_prop(extended, "UserAuthenticationMethod"),
        "device_properties":   _maybe_json(g("DeviceProperties")),
        "extended_properties": _maybe_json(extended) if extended else None,
        "actor_ip_address":    g("ActorIpAddress"),
        "modified_properties": _maybe_json(g("ModifiedProperties")),
        "parameters":          _maybe_json(g("Parameters")),
        "operation_properties": _maybe_json(g("OperationProperties")),
        "actor_upn":           _normalize_upn(_first_upn_id(g("Actor"))),
        "target_upn":          _normalize_upn(_first_upn_id(g("Target"))),
        "site":                g("Site") or g("SiteUrl"),
        "web_id":              g("WebId"),
        "list_id":             g("ListId"),
        "list_item_unique_id": g("ListItemUniqueId"),
        "source_file_name":    g("SourceFileName"),
        "source_relative_url": g("SourceRelativeUrl"),
        "item_type":           g("ItemType"),
        # client_app_id is now the alias for the *initiating* app id, which
        # for nearly every event is the same as application_id; we keep it
        # populated as a deprecated convenience for now.
        "client_app_id":       _first_present(audit, "AppId", "ClientAppId"),
        "client_app_name":     g("ClientAppName") or g("ApplicationDisplayName"),
        "browser_name":        g("BrowserName"),
        "browser_version":     g("BrowserVersion"),
        "platform":            g("Platform"),
        "is_managed_device":   (1 if is_managed else 0) if isinstance(is_managed, bool) else None,
        "device_display_name": g("DeviceDisplayName"),
        "mail_item_count":     None,
    }

    specialiser = _SPECIALIZERS.get(promoted["record_type_int"])
    if specialiser is not None:
        specialiser(audit, promoted)

    return promoted


def _spec_aad_sts_logon(audit: dict, promoted: dict) -> None:
    """RecordType 8: AzureActiveDirectoryStsLogon (interactive sign-in).

    AAD STS-logon events store the source IP as ``IPAddress`` (no Client
    prefix), put the user-agent inside ``ExtendedProperties``, and routinely
    emit ``LogonError`` (e.g. ``InvalidUserNameOrPassword``,
    ``UserStrongAuthClientAuthNRequired``) which is the granular failure
    reason.  ``_first_present`` already covered ``IPAddress``; the only thing
    this specialiser needs to do is surface ``LogonError`` into the
    ``result_status_detail`` column when it's the most informative value.
    """
    if not promoted.get("result_status_detail"):
        promoted["result_status_detail"] = audit.get("LogonError")


def _spec_aad_consent(audit: dict, promoted: dict) -> None:
    """RecordType 15: AzureActiveDirectory (consent / app-role / SP events).

    No scalar fix-ups beyond the defaults; the rich detail lives in
    ``Target`` / ``ModifiedProperties`` and is structured into the
    ``consent_grants`` child table by ``extract_consent_grants``.
    """
    return None


def _spec_exchange_item_aggregated(audit: dict, promoted: dict) -> None:
    """RecordType 50: ExchangeItemAggregated -- ``MailItemsAccessed``.

    These events aggregate up to N mail-item accesses into one audit row.
    The default promoter handles ``ClientIPAddress`` and ``AppId`` via
    aliases; this specialiser surfaces the per-event item count from
    ``OperationCount`` so analysts can tell at a glance whether a row covers
    1 read or 50.  Per-message detail is structured into
    ``mail_items_accessed`` by ``extract_mia_rows``.
    """
    oc = audit.get("OperationCount")
    if isinstance(oc, int):
        promoted["mail_item_count"] = oc
    elif isinstance(oc, str) and oc.isdigit():
        promoted["mail_item_count"] = int(oc)


_SPECIALIZERS = {
    8:  _spec_aad_sts_logon,
    15: _spec_aad_consent,
    50: _spec_exchange_item_aggregated,
}


