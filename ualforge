# ---------------------------------------------------------------------------
# --reextract: rebuild promoted columns + child tables in place
# ---------------------------------------------------------------------------

_REEXTRACT_BATCH = 5000


# Names of indexes that we drop (and re-create) around the reextract.
# These exist on tables that get heavy bulk INSERT activity; keeping
# the indexes live during the bulk load makes inserts O(N log N) instead
# of O(N), which on a 9 GB / 1M-row database is the difference between
# minutes and hours.  The CREATE statements live in _INDEX_DDL so
# init_schema rebuilds them after we're done.
_REEXTRACT_DROP_INDEXES: tuple[str, ...] = (
    "idx_mia_event_row", "idx_mia_upn", "idx_mia_imid",
    "idx_mia_subj", "idx_mia_created",
    "idx_cg_event_row", "idx_cg_upn", "idx_cg_app", "idx_cg_created",
    # NB: the uq_mia_event_item and uq_cg_event_app UNIQUE indexes are
    # intentionally NOT dropped -- they are the dedup mechanism that lets
    # INSERT OR IGNORE collapse near-duplicates emitted by Microsoft when
    # the same message appears in multiple folders or the same event row
    # is paged across export files.  Dropping them would let duplicate
    # rows accumulate that we couldn't even rebuild the index over.
)


def reextract_db(db_path: Path, *, log_path: Path | None = None) -> int:
    """Walk every event row, re-run the promoter, rebuild child tables.

    Used to upgrade a database whose ``user_version`` is older than the
    current ``SCHEMA_VERSION`` without having to re-read source CSVs --
    the canonical auditData JSON is always preserved in
    ``events.audit_data_canonical``.

    Implementation notes (the things that make this fast on a 9 GB / 1M-row
    database):

    - Two connections: ``conn_r`` reads, ``conn_w`` writes.  In WAL mode
      readers and writers don't block each other, but interleaving them on
      the same connection causes page-cache thrash and prematurely
      materialises the read cursor.
    - Read cursor uses ``fetchmany(_REEXTRACT_BATCH)`` so we never hold a
      whole-table result-set in memory and never round-trip per row.
    - Writes happen inside one ``BEGIN IMMEDIATE ... COMMIT`` so SQLite
      only fsyncs at the end (acceptable: if we crash, the transaction
      rolls back atomically, the v1 data is unchanged, and the analyst
      simply re-runs --reextract).
    - Child-table indexes are dropped before the bulk insert and rebuilt
      at the end via ``init_schema`` -- O(N) inserts beat O(N log N) on a
      million rows by orders of magnitude.
    """
    if not db_path.exists():
        err(f"{_SCRIPT_NAME}: --reextract target does not exist: {db_path}")
        return 2

    conn_w = open_db(db_path)
    conn_r = sqlite3.connect(db_path)  # plain read connection, no PRAGMAs needed
    try:
        # ---- version check + structural migration --------------------------
        cur_ver = conn_w.execute("PRAGMA user_version").fetchone()[0]
        if cur_ver == SCHEMA_VERSION:
            info(f"  Database already at schema_version={SCHEMA_VERSION}; "
                 "re-extracting will refresh promoted columns + child tables.")
        elif cur_ver == 1:
            info(f"  Upgrading database from schema_version=1 to {SCHEMA_VERSION}.")
            _migrate_events_v1_to_v2(conn_w)
        else:
            err(
                f"{_SCRIPT_NAME}: --reextract cannot handle "
                f"user_version={cur_ver}; this {APP_NAME} only knows how to "
                f"upgrade from v1 -> v{SCHEMA_VERSION}."
            )
            return 2

        # init_schema creates missing tables and indexes (idempotent).
        init_schema(conn_w)

        ingested_at = datetime.now(UTC).isoformat(timespec="seconds")
        cur = conn_w.execute(
            "INSERT INTO ingest_runs(started_at, app_version, argv, mode, "
            "input_dir, status) VALUES (?,?,?, 'reextract', ?, 'running')",
            (ingested_at, VERSION, " ".join(sys.argv), str(db_path)),
        )
        run_id = cur.lastrowid
        conn_w.commit()

        total = conn_r.execute("SELECT COUNT(*) FROM events").fetchone()[0]
        info(f"  Re-promoting {total:,} event(s)...")

        # ---- bulk-mode PRAGMAs --------------------------------------------
        # synchronous=OFF is safe inside the wrapping BEGIN IMMEDIATE: a crash
        # rolls back the entire transaction.  We restore NORMAL at the end.
        conn_w.execute("PRAGMA synchronous = OFF")

        # ---- drop child-table indexes for the duration of the load --------
        for ix in _REEXTRACT_DROP_INDEXES:
            conn_w.execute(f"DROP INDEX IF EXISTS {ix}")

        update_cols = [c for c in _EVENT_COLUMNS if c not in {
            "row_hash", "source_file", "source_line", "export_batch",
            "ingested_at", "ingest_run_id", "parse_error",
            "audit_data_raw", "audit_data_canonical",
            # CSV-derived fields: keep as-is from original ingest.
            "id", "created_at_raw", "audit_log_record_type",
            "operation", "organization_id", "user_type", "user_id", "service",
            "object_id", "client_ip_csv", "administrative_units",
        }]
        update_sql = (
            "UPDATE events SET " + ", ".join(f"{c}=?" for c in update_cols)
            + " WHERE row_hash=?"
        )

        # ---- one giant transaction ----------------------------------------
        conn_w.execute("BEGIN IMMEDIATE")
        try:
            # Wipe child rows so we can repopulate idempotently (now that indexes
            # are gone, this is fast even on a huge table).
            conn_w.execute("DELETE FROM mail_items_accessed")
            conn_w.execute("DELETE FROM consent_grants")

            scanned = updated = mia_added = cg_added = 0

            cur_r = conn_r.execute(
                "SELECT row_hash, id, created_at_raw, operation, "
                "client_ip_csv, audit_data_canonical FROM events"
            )

            while True:
                rows = cur_r.fetchmany(_REEXTRACT_BATCH)
                if not rows:
                    break
                upd_buf: list[tuple] = []
                mia_buf: list[tuple] = []
                cg_buf: list[tuple] = []
                for row in rows:
                    scanned += 1
                    (rh, ev_id, raw_dt, op, csv_ip, audit_canon) = row
                    audit_obj = None
                    if audit_canon:
                        try:
                            audit_obj = json.loads(audit_canon)
                        except (json.JSONDecodeError, ValueError):
                            audit_obj = None
                    audit_dict = audit_obj if isinstance(audit_obj, dict) else {}
                    promoted = extract_promoted(audit_dict, csv_ip)

                    iso_dt: str | None = None
                    if isinstance(audit_obj, dict):
                        iso_dt = parse_created_dt(audit_obj.get("CreationTime") or "")
                    if iso_dt is None and raw_dt:
                        iso_dt = parse_created_dt(raw_dt)

                    upn_norm = _normalize_upn(audit_dict.get("UserId"))
                    upn_raw = audit_dict.get("UserId")

                    # values aligned with update_cols (do not realign without
                    # also updating update_cols above)
                    vals = [
                        iso_dt,                                # created_at_utc
                        upn_norm,                              # user_principal_name
                        upn_raw,                               # user_principal_name_raw
                        promoted["workload"],
                        promoted["client_ip"],
                        promoted["client_ip_raw"],
                        promoted["user_agent"],
                        promoted["geo_location"],
                        promoted["event_source"],
                        promoted["result_status"],
                        promoted["result_status_detail"],
                        promoted["correlation_id"],
                        promoted["application_id"],
                        promoted["user_key"],
                        promoted["record_type_int"],
                        promoted["mailbox_owner_upn"],
                        promoted["mailbox_guid"],
                        promoted["logon_type"],
                        promoted["client_info_string"],
                        promoted["internet_message_id"],
                        promoted["item_subject"],
                        promoted["item_parent_folder_path"],
                        promoted["session_id"],
                        promoted["logon_user_sid"],
                        promoted["authentication_type"],
                        promoted["request_type"],
                        promoted["user_authentication_method"],
                        promoted["device_properties"],
                        promoted["extended_properties"],
                        promoted["actor_ip_address"],
                        promoted["modified_properties"],
                        promoted["parameters"],
                        promoted["operation_properties"],
                        promoted["actor_upn"],
                        promoted["target_upn"],
                        promoted["site"],
                        promoted["web_id"],
                        promoted["list_id"],
                        promoted["list_item_unique_id"],
                        promoted["source_file_name"],
                        promoted["source_relative_url"],
                        promoted["item_type"],
                        promoted["client_app_id"],
                        promoted["client_app_name"],
                        promoted["browser_name"],
                        promoted["browser_version"],
                        promoted["platform"],
                        promoted["is_managed_device"],
                        promoted["device_display_name"],
                        promoted["mail_item_count"],
                    ]
                    # Sanity-guard: vals must align 1:1 with update_cols.
                    # If you add a column to update_cols above, you must add
                    # its value here in the same position.
                    assert len(vals) == len(update_cols), (
                        f"reextract values/columns drift: "
                        f"{len(vals)} vs {len(update_cols)}"
                    )
                    upd_buf.append(tuple(vals) + (rh,))

                    mia_buf.extend(extract_mia_rows(
                        audit_dict,
                        event_row_hash=rh, event_id=ev_id, ingest_run_id=run_id,
                        user_principal_name=upn_norm,
                        client_ip=promoted["client_ip"],
                        created_at_utc=iso_dt,
                        operation=op,
                        mailbox_owner_upn=promoted["mailbox_owner_upn"],
                    ))
                    cg_buf.extend(extract_consent_grants(
                        audit_dict,
                        event_row_hash=rh, event_id=ev_id, ingest_run_id=run_id,
                        user_principal_name=upn_norm,
                        client_ip=promoted["client_ip"],
                        created_at_utc=iso_dt,
                        operation=op,
                    ))

                if upd_buf:
                    conn_w.executemany(update_sql, upd_buf)
                    updated += len(upd_buf)
                if mia_buf:
                    cur2 = conn_w.executemany(_MIA_INSERT_SQL, mia_buf)
                    mia_added += cur2.rowcount if cur2.rowcount and cur2.rowcount >= 0 else 0
                if cg_buf:
                    cur2 = conn_w.executemany(_CG_INSERT_SQL, cg_buf)
                    cg_added += cur2.rowcount if cur2.rowcount and cur2.rowcount >= 0 else 0

                # progress every batch
                if scanned % 50_000 < _REEXTRACT_BATCH:
                    info(
                        f"     ... {scanned:,} of {total:,} re-promoted "
                        f"(mia {mia_added:,}, consent {cg_added:,})"
                    )

            conn_w.execute("COMMIT")
        except Exception:
            conn_w.execute("ROLLBACK")
            raise
        finally:
            conn_w.execute("PRAGMA synchronous = NORMAL")

        # ---- rebuild dropped indexes --------------------------------------
        info("  Rebuilding child-table indexes...")
        for ddl in _INDEX_DDL:
            conn_w.execute(ddl)
        conn_w.commit()

        end = datetime.now(UTC)
        # In reextract mode coverage is DB-wide (no run_id filter): the run
        # we just executed touches every existing event but does NOT change
        # their original ingest_run_id, so a per-run filter would always
        # report 0 rows.  The whole-database view is what the analyst (and
        # bec-triage's banner) actually want anyway.
        cov = compute_coverage(conn_w, None)
        conn_w.execute(
            "UPDATE ingest_runs SET ended_at=?, files_processed=0, "
            "rows_seen=?, rows_inserted=?, rows_duplicate=0, "
            "rows_with_errors=0, mia_rows_emitted=?, "
            "consent_rows_emitted=?, coverage_json=?, status='ok' "
            "WHERE run_id=?",
            (
                end.isoformat(timespec="seconds"),
                scanned, updated, mia_added, cg_added,
                canonical_json(cov),
                run_id,
            ),
        )
        conn_w.commit()

        elapsed = _format_duration(end - _RUN_START)
        ok(f"  Re-extract complete in {elapsed}: {scanned:,} events scanned, "
           f"{updated:,} updated, "
           f"{mia_added:,} mail-item rows, {cg_added:,} consent rows.")
        _emit_coverage(cov)
        return 0
    finally:
        try:
            conn_w.execute("PRAGMA optimize")
        except sqlite3.Error:
            pass
        conn_w.close()
        conn_r.close()


def _migrate_events_v1_to_v2(conn: sqlite3.Connection) -> None:
    """Add v2-only columns to a v1 ``events`` table.  ``init_schema`` will
    add the new tables and indexes; this only handles ``ALTER TABLE`` for
    columns that ``CREATE TABLE IF NOT EXISTS`` won't add to an existing
    table.
    """
    cols = {
        r[1] for r in conn.execute("PRAGMA table_info(events)").fetchall()
    }
    new_cols = [
        ("user_principal_name_raw", "TEXT"),
        ("client_ip_raw", "TEXT"),
        ("result_status_detail", "TEXT"),
        ("request_type", "TEXT"),
        ("user_authentication_method", "TEXT"),
        ("extended_properties", "TEXT"),
        ("mail_item_count", "INTEGER"),
    ]
    for name, ctype in new_cols:
        if name not in cols:
            conn.execute(f"ALTER TABLE events ADD COLUMN {name} {ctype}")
    # ingest_runs additions:
    irc = {r[1] for r in conn.execute("PRAGMA table_info(ingest_runs)").fetchall()}
    for name, ctype in [
        ("mode", "TEXT"),
        ("mia_rows_emitted", "INTEGER DEFAULT 0"),
        ("consent_rows_emitted", "INTEGER DEFAULT 0"),
        ("coverage_json", "TEXT"),
    ]:
        if name not in irc:
            conn.execute(f"ALTER TABLE ingest_runs ADD COLUMN {name} {ctype}")
    conn.commit()


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

def main(argv: list[str] | None = None) -> int:
    args = _build_parser().parse_args(argv)

    # auditData blobs can be very large; raise the csv module's per-field cap.
    csv.field_size_limit(min(sys.maxsize, 2**31 - 1))

    # --reextract takes its own short path (no INPUT_DIR, no CSV reading).
    if args.reextract:
        if args.input_dir:
            err(
                f"{_SCRIPT_NAME}: --reextract takes a database path as its "
                "value, not an input directory; remove the trailing "
                f"INPUT_DIR argument ({args.input_dir!r})."
            )
            return 2
        db_path = Path(args.reextract).resolve()
        if args.log:
            log_path = _resolve_log_path(db_path.parent)
            try:
                _LOG.open(log_path)
            except OSError as e:
                err(f"{_SCRIPT_NAME}: could not open log file {log_path}: {e}")
                return 2
        header(f"{_SCRIPT_NAME} {VERSION}  --  re-extract mode")
        info(f"Started:   {_TS_DISPLAY}")
        if _LOG.path is not None:
            info(f"Log file:  {_LOG.path}")
        info(f"Database:  {db_path}")
        blank()
        return reextract_db(db_path, log_path=_LOG.path)

    if not args.input_dir:
        err(
            f"{_SCRIPT_NAME}: INPUT_DIR is required when using -o / -a "
            "(only --reextract may omit it)."
        )
        return 2
    input_dir = Path(args.input_dir).resolve()
    if not input_dir.exists():
        err(f"{_SCRIPT_NAME}: input directory does not exist: {input_dir}")
        return 2
    if not input_dir.is_dir():
        err(f"{_SCRIPT_NAME}: input path is not a directory: {input_dir}")
        return 2

    if args.append:
        db_path = Path(args.append).resolve()
        ok_v, reason = verify_ualforge_db(db_path)
        if not ok_v:
            err(f"{_SCRIPT_NAME}: --append target is not a ualforge database: {reason}")
            return 2
        out_dir = db_path.parent
        mode = "append (explicit)"
    else:
        out_dir = Path(args.output).resolve()
        if out_dir.exists() and not out_dir.is_dir():
            err(f"{_SCRIPT_NAME}: --output path exists but is not a directory: {out_dir}")
            return 2
        try:
            out_dir.mkdir(parents=True, exist_ok=True)
        except OSError as e:
            err(f"{_SCRIPT_NAME}: could not create output directory {out_dir}: {e}")
            return 2
        db_path = out_dir / f"{APP_NAME}-{_TS_DATE}.sqlite"
        if db_path.exists():
            ok_v, reason = verify_ualforge_db(db_path)
            if not ok_v:
                err(
                    f"{_SCRIPT_NAME}: existing file {db_path} is not a "
                    f"ualforge database: {reason}"
                )
                return 2
            mode = "append (same-day)"
        else:
            mode = "create"

    if args.log:
        log_path = _resolve_log_path(out_dir)
        try:
            _LOG.open(log_path)
        except OSError as e:
            err(f"{_SCRIPT_NAME}: could not open log file {log_path}: {e}")
            return 2

    header(f"{_SCRIPT_NAME} {VERSION}")
    info(f"Started:   {_TS_DISPLAY}")
    if _LOG.path is not None:
        info(f"Log file:  {_LOG.path}")
    info(f"Database:  {db_path}  [{mode}]")
    info(f"Scanning:  {input_dir}")
    blank()

    csvs, rejected = find_ual_csvs(input_dir)
    if not csvs:
        warn(f"No UAL CSV files found under {input_dir}. Nothing to do.")
        if rejected:
            warn(f"({len(rejected)} candidate file(s) rejected by structural check.)")
        return 0
    info(f"Found {len(csvs)} UAL CSV file(s).")
    if rejected:
        warn(f"  ({len(rejected)} other CSV(s) rejected by header check.)")

    conn = open_db(db_path)
    try:
        init_schema(conn)
        ingested_at = datetime.now(UTC).isoformat(timespec="seconds")
        cur = conn.execute(
            "INSERT INTO ingest_runs(started_at, app_version, argv, mode, "
            "input_dir, status) VALUES (?,?,?,?,?, 'running')",
            (ingested_at, VERSION, " ".join(sys.argv), mode, str(input_dir)),
        )
        run_id = cur.lastrowid
        conn.commit()

        totals = {
            "seen": 0, "inserted": 0, "duplicate": 0, "errors": 0,
            "mia_emitted": 0, "consent_emitted": 0,
        }
        files_processed = 0
        for i, csv_path in enumerate(csvs, 1):
            blank()
            header(f"[{i}/{len(csvs)}] {csv_path.name}")
            stats = process_file(conn, csv_path, input_dir, run_id, ingested_at)
            files_processed += 1
            for k in totals:
                totals[k] += stats.get(k, 0)

        end = datetime.now(UTC)
        cov = compute_coverage(conn, run_id)
        conn.execute(
            "UPDATE ingest_runs SET ended_at=?, files_processed=?, "
            "rows_seen=?, rows_inserted=?, rows_duplicate=?, "
            "rows_with_errors=?, mia_rows_emitted=?, consent_rows_emitted=?, "
            "coverage_json=?, status='ok' WHERE run_id=?",
            (
                end.isoformat(timespec="seconds"),
                files_processed,
                totals["seen"],
                totals["inserted"],
                totals["duplicate"],
                totals["errors"],
                totals["mia_emitted"],
                totals["consent_emitted"],
                canonical_json(cov),
                run_id,
            ),
        )
        conn.commit()
        _emit_summary(
            files_count=files_processed,
            totals=totals,
            db_path=db_path,
            run_end=end,
        )
        _emit_coverage(cov)

        if rejected:
            blank()
            header("Rejected files")
            for p, reason in rejected:
                try:
                    rel = p.relative_to(input_dir).as_posix()
                except ValueError:
                    rel = str(p)
                warn(f"  {rel}: {reason}")
        return 0
    finally:
        try:
            conn.execute("PRAGMA optimize")
        except sqlite3.Error:
            pass
        conn.close()


if __name__ == "__main__":
    sys.exit(main())
