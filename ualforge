class _ColorVersionAction(argparse.Action):
    def __init__(
        self,
        option_strings,
        version=None,
        dest=argparse.SUPPRESS,
        default=argparse.SUPPRESS,
        help="show program's version number and exit",
    ):
        super().__init__(
            option_strings=option_strings,
            dest=dest,
            default=default,
            nargs=0,
            help=help,
        )
        self.version = version

    def __call__(self, parser, namespace, values, option_string=None):
        print()
        print(f"  {paint(_SCRIPT_NAME, BOLD, CYAN)}  {paint(VERSION, BOLD, GREEN)}")
        print()
        parser.exit()


def _colorize_help(text: str) -> str:
    if not _USE_COLOR:
        return text
    text = re.sub(r"(?m)^(usage:)", f"{BOLD}{MAGENTA}\\1{RESET}", text)
    text = re.sub(
        r"(?m)^(positional arguments|options|examples|notes):",
        f"{BOLD}{CYAN}\\1{RESET}:",
        text,
    )
    text = re.sub(
        r"(?<![\w-])(--?[A-Za-z][\w-]*)",
        f"{GREEN}\\1{RESET}",
        text,
    )
    text = re.sub(
        r"\b([A-Z][A-Z0-9_]{1,})\b",
        f"{CYAN}\\1{RESET}",
        text,
    )
    return text


class _ColorParser(argparse.ArgumentParser):
    def format_help(self) -> str:
        return "\n" + _colorize_help(super().format_help())


def _build_parser() -> argparse.ArgumentParser:
    parser = _ColorParser(
        prog=_SCRIPT_NAME,
        description=(
            "Parse Microsoft 365 Unified Audit Log CSVs into a SQLite "
            "database for DFIR / BEC investigations."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "examples:\n"
            f"  {_SCRIPT_NAME} -o ./out ./ualevidence\n"
            f"  {_SCRIPT_NAME} -a ./out/ualforge-20260427.sqlite -l ./more-ualevidence\n"
        ),
    )
    parser.add_argument(
        "-v", "--version",
        action=_ColorVersionAction,
        version=f"{_SCRIPT_NAME} {VERSION}",
    )
    target = parser.add_mutually_exclusive_group(required=True)
    target.add_argument(
        "-o", "--output",
        metavar="DIR",
        help=(
            "output directory; database is written to "
            "<DIR>/ualforge-yyyymmdd.sqlite. If that file already "
            "exists it must be a ualforge database and is appended to."
        ),
    )
    target.add_argument(
        "-a", "--append",
        metavar="DB",
        help=(
            "append to an existing ualforge SQLite database "
            "(must already exist and pass schema verification)."
        ),
    )
    target.add_argument(
        "--reextract",
        metavar="DB",
        help=(
            "re-run the auditData -> promoted-columns + child-tables "
            "extraction in place, against the canonical JSON already "
            "stored in the database; no source CSV is re-read.  Use this "
            "to upgrade a v1 database to v2, or to refresh promoted "
            "values after a future promoter improvement.  No INPUT_DIR."
        ),
    )
    parser.add_argument(
        "-l", "--log",
        action="store_true",
        help=f"write a {LOG_PREFIX}-yyyymmdd-hhmmss.log next to the database",
    )
    parser.add_argument(
        "input_dir",
        metavar="INPUT_DIR",
        nargs="?",
        help=(
            "directory to recursively scan for UAL CSV files "
            "(required for -o / -a; ignored for --reextract)"
        ),
    )
    return parser


def _resolve_log_path(out_dir: Path) -> Path:
    target = out_dir / f"{LOG_PREFIX}-{_TS_FILENAME}.log"
    if not target.exists():
        return target
    counter = 1
    while True:
        candidate = out_dir / f"{LOG_PREFIX}-{_TS_FILENAME}-{counter}.log"
        if not candidate.exists():
            return candidate
        counter += 1


def _format_duration(td) -> str:
    total = int(td.total_seconds())
    hours, rem = divmod(total, 3600)
    minutes, seconds = divmod(rem, 60)
    return f"{hours:d}:{minutes:02d}:{seconds:02d}"


